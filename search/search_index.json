1\u4e3b\u9078\u55ae\u9032\u5165\u300c\u7dad\u8b77\u8a2d\u5099\u9032\u5ea6\u8ffd\u8e64\u770b\u677f\u300d\u3002</li> <li>\u67e5\u8a62\u689d\u4ef6\u5f8c\u6aa2\u8996\u770b\u677f\u3002</li> <li>\u4f9d\u9700\u8981\u532f\u51fa\u6216\u622a\u5716\u5206\u4eab\u3002</li> </ol>"},{"location":"guides/prototype_MCR310/","title":"MCR310 \u5ba2\u6236\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u5efa\u6a94\uff5c\u64cd\u4f5c\u8aaa\u660e","text":"<ul> <li>\u7a0b\u5f0f\u4ee3\u865f\uff1a MCR310</li> <li>\u96db\u578b\u6a94\u540d\uff1a prototype_MCR310.html</li> <li>\u66f4\u65b0\u65e5\uff1a 2026-02-26</li> </ul>"},{"location":"guides/prototype_MCR310/#_1","title":"\u7a0b\u5f0f\u8aaa\u660e\u8207\u4f55\u6642\u4f7f\u7528","text":"<p>\u672c\u7a0b\u5f0f\u7528\u65bc\u5ba2\u6236\u5408\u7d04\u7c3d\u8a02\u6642\uff0c\u5c07\u8a72\u5408\u7d04\u4e4b\u5de5\u4f5c\u9805\u76ee\u3001\u9805\u6b21\u3001\u55ae\u50f9\u8207\u9810\u7b97\u91d1\u984d\u5efa\u6a94\uff0c\u4f5c\u70ba\u5f8c\u7e8c\u8acb\u6b3e\u55ae\u50f9\u8207\u7d50\u7b97\u4f9d\u64da\u3002</p> <p>\u4f5c\u696d\u9806\u5e8f\uff1a\u5148\u9078\u5165\u5408\u7d04\uff0c\u518d\u532f\u5165\u5de5\u4f5c\u9805\u6b21\u8207\u55ae\u50f9\u3002</p> \u4f7f\u7528\u6642\u6a5f \u8aaa\u660e \u65b0\u5408\u7d04\u7c3d\u8a02 \u6536\u5230\u5ba2\u6236\u5408\u7d04\u5f8c\uff0c\u9700\u5efa\u7acb\u8a72\u5408\u7d04\u7684\u5de5\u4f5c\u9805\u76ee\u8207\u55ae\u50f9\uff0c\u4f9b MCR330 \u56de\u5831\u5b8c\u5de5\u8acb\u6b3e\u8a66\u7b97\u5957\u7528\u3002 \u5408\u7d04\u8b8a\u66f4 \u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u6216\u55ae\u50f9\u7570\u52d5\u6642\uff0c\u65bc\u672c\u7a0b\u5f0f\u66f4\u65b0\u6216\u91cd\u65b0\u532f\u5165\u3002 \u521d\u6b21\u5efa\u6a94 \u53ef\u5148\u300c\u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u300d\u586b\u5beb\uff0c\u518d\u4ee5\u300c\u6279\u6b21\u532f\u5165\u300d\u4e0a\u50b3\uff0c\u6e1b\u5c11\u9010\u7b46\u8f38\u5165\u3002 <p>\u91cd\u65b0\u532f\u5165\uff1a\u82e5\u6b64\u5408\u7d04\u5df2\u6709\u5de5\u4f5c\u9805\u76ee\u8cc7\u6599\uff0c\u57f7\u884c\u6279\u6b21\u532f\u5165\u6642\u7cfb\u7d71\u6703\u63d0\u9192\u300c\u662f\u5426\u6e05\u9664\u539f\u6709\u8cc7\u6599\u300d\uff1b\u78ba\u8a8d\u300c\u662f\u300d\u5247\u6a19\u8a18\u522a\u9664\u539f\u8cc7\u6599\u4e26\u5168\u90e8\u65b0\u589e\u91cd\u532f\uff0c\u4ee5\u7dad\u6301\u8cc7\u6599\u5b8c\u6574\u6027\uff0c\u907f\u514d\u91cd\u8907\u6216\u907a\u7559\u4e0a\u6b21\u8cc7\u6599\u5dee\u7570\u3002</p>"},{"location":"guides/prototype_MCR310/#_2","title":"\u4e00\u3001\u756b\u9762\u5340\u584a","text":"\u5340\u584a \u8aaa\u660e \u64cd\u4f5c\u63d0\u793a \u203b \u8acb\u5148\u9078\u64c7\u5408\u7d04\uff0c\u518d\u4e0b\u8f09\u7bc4\u672c\u6216\u6279\u6b21\u532f\u5165\u5de5\u4f5c\u9805\u6b21\u8207\u55ae\u50f9\u3002 \u9802\u5217 \u8fd4\u56de\u3001\u7a0b\u5f0f\u6a19\u984c\uff1b\u53f3\u4e0a\u65b9\u300c\ud83d\udcd6 \u64cd\u4f5c\u8aaa\u660e\u300d\u53ef\u958b\u555f\u672c\u8aaa\u660e\u3002 \u64cd\u4f5c\u5217 \u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u3001\u6279\u6b21\u532f\u5165\u3001\u5408\u7d04\u7be9\u9078\u3001\u67e5\u8a62\u3002\uff08\u672c\u4f5c\u696d\u4ee5\u6279\u6b21\u532f\u5165\u70ba\u4e3b\uff0c\u4e0d\u63d0\u4f9b\u55ae\u7b46\u65b0\u589e\uff09 \u5408\u7d04\u8aaa\u660e\u5217 \u986f\u793a\u76ee\u524d\u5408\u7d04\u8207\u532f\u5165\u67e5\u8a62\u8aaa\u660e\u3002 \u672a\u5c0d\u61c9\u9805\u76ee\u63d0\u793a \u532f\u5165\u5f8c\u82e5\u6aa2\u67e5\u5230\u8a2d\u5099\u5de5\u4f5c\u9805\u76ee\u5c0d\u61c9\u4e0d\u5230\u65b0\u5408\u7d04\uff0c\u4ee5\u7d05\u8272\u986f\u793a\u7b46\u6578\uff0c\u9ede\u9078\u53ef\u5217\u51fa\u6e05\u55ae\uff08\u5de5\u4f5c\u9805\u76ee\u3001\u8a2d\u5099\u7de8\u865f\uff09\u3002 \u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u6e05\u55ae \u8868\u683c\u8207\u5206\u9801\u3001\u532f\u51fa\u5168\u90e8 Excel\u3002"},{"location":"guides/prototype_MCR310/#_3","title":"\u4e8c\u3001\u4e3b\u8981\u6b04\u4f4d","text":"<ul> <li>\u9805\u6b21\u3001\u9805\u6b21\u7de8\u865f\u3001\u5de5\u4f5c\u9805\u76ee\u540d\u7a31\u3001\u55ae\u4f4d\u3001\u6578\u91cf\u3001\u55ae\u50f9\u3001\u7e3d\u50f9\uff08\u9810\u7b97\u91d1\u984d\uff09\u3001\u8ffd\u52a0\u9805\u8b58\u5225\u3001\u7570\u52d5\u65e5\u671f\u3001\u64cd\u4f5c\uff08\u7de8\u8f2f\uff0f\u522a\u9664\uff09\u3002</li> </ul>"},{"location":"guides/prototype_MCR310/#_4","title":"\u4e09\u3001\u64cd\u4f5c\u6b65\u9a5f","text":"<ol> <li>\u5148\u9078\u5165\u5408\u7d04\uff1a\u65bc\u5408\u7d04\u7be9\u9078\u9078\u64c7\u8981\u5efa\u6a94\u7684\u5408\u7d04\u5f8c\u9ede\u300c\u67e5\u8a62\u300d\u3002</li> <li>\u521d\u6b21\u5efa\u6a94\uff1a\u9ede\u300c\u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u300d\u53d6\u5f97 CSV \u7bc4\u672c\uff0c\u4f9d\u6b04\u4f4d\u586b\u5beb\u5f8c\u518d\u9ede\u300c\u6279\u6b21\u532f\u5165\u300d\u4e0a\u50b3\u3002</li> <li>\u9ede\u300c\u6279\u6b21\u532f\u5165\u300d\u4e0a\u50b3\u8a72\u5408\u7d04\u4e4b\u5de5\u4f5c\u9805\u6b21\u8207\u55ae\u50f9\u3002\u82e5\u6b64\u5408\u7d04\u5df2\u6709\u8cc7\u6599\uff0c\u7cfb\u7d71\u6703\u8a62\u554f\u300c\u662f\u5426\u6e05\u9664\u539f\u6709\u8cc7\u6599\u300d\uff0c\u78ba\u8a8d\u300c\u662f\u300d\u5247\u6a19\u8a18\u522a\u9664\u539f\u8cc7\u6599\u4e26\u5168\u90e8\u65b0\u589e\u91cd\u532f\uff0c\u7dad\u6301\u5b8c\u6574\u6027\u3002</li> <li>\u532f\u5165\u5f8c\u7cfb\u7d71\u6703\u6aa2\u67e5\u8a2d\u5099\u5de5\u4f5c\u9805\u76ee\u662f\u5426\u5c0d\u61c9\u5230\u65b0\u5408\u7d04\uff1b\u82e5\u6709\u300c\u672a\u5c0d\u61c9\u9805\u76ee\u300d\u7d05\u8272\u63d0\u793a\uff0c\u9ede\u9078\u53ef\u67e5\u770b\u5de5\u4f5c\u9805\u76ee\u8207\u8a2d\u5099\u7de8\u865f\u6e05\u55ae\uff0c\u4e26\u81f3 MCR320 \u5ba2\u6236\u8a2d\u5099\u5c0d\u61c9\u5de5\u4f5c\u9805\u76ee\u5efa\u6a94 \u66f4\u65b0\u8a2d\u5099\u5c0d\u61c9\u5de5\u4f5c\u9805\u76ee\u3002</li> <li>\u53ef\u300c\u532f\u51fa\u5168\u90e8 Excel\u300d\u532f\u51fa\u6e05\u55ae\uff1b\u55ae\u7b46\u4fee\u6b63\u53ef\u65bc\u6e05\u55ae\u4e0a\u4f7f\u7528\u7de8\u8f2f\uff0f\u522a\u9664\u3002</li> </ol>"},{"location":"guides/prototype_MCR310/#_5","title":"\u56db\u3001\u96db\u578b\u8207\u7bc4\u672c\u9023\u7d50","text":"<ul> <li>\u672c\u96db\u578b\uff1a prototype_MCR310.html</li> <li>\u672c\u64cd\u4f5c\u8aaa\u660e\uff1a \u672c\u6a94</li> <li>\u532f\u5165\u7bc4\u672c\uff1a prototype_MCR310_\u532f\u5165\u7bc4\u672c.csv</li> </ul>"},{"location":"guides/prototype_MCR320/","title":"MCR320 \u5ba2\u6236\u8a2d\u5099\u5c0d\u61c9\u5de5\u4f5c\u9805\u76ee\u5efa\u6a94\uff5c\u64cd\u4f5c\u8aaa\u660e","text":"<ul> <li>\u7a0b\u5f0f\u4ee3\u865f\uff1a MCR320</li> <li>\u96db\u578b\u6a94\u540d\uff1a prototype_MCR320.html</li> <li>\u66f4\u65b0\u65e5\uff1a 2026-02-26</li> </ul>"},{"location":"guides/prototype_MCR320/#_1","title":"\u7a0b\u5f0f\u8aaa\u660e\u8207\u4f55\u6642\u4f7f\u7528","text":"<p>\u672c\u7a0b\u5f0f\u5efa\u6a94\u7dad\u4fee\u5ee0\u5340\u8a2d\u5099\u4e4b\u6a19\u6e96\u5de5\u4f5c\u9805\u76ee\u3001\u6578\u91cf\u8207\u9810\u8a2d\u52a0\u6210\u6bd4\u4f8b\uff0c\u4f9b MCR330 \u8a66\u7b97\u8207 MCR340 \u52a0\u6210\u4f5c\u696d\u4f7f\u7528\u3002\u5c0d\u61c9\u5ee0\u5340\u8a2d\u5099\u6e05\u55ae\uff0c\u4e0d\u5c0d\u61c9\u5408\u7d04\u3002</p> <p>\u4f5c\u696d\u9806\u5e8f\uff1a\u5148\u9078\u5ee0\u5340 + \u8a2d\u5099\u7de8\u865f\uff08\u55ae\u4e00\u8a2d\u5099\uff09\uff0c\u518d\u532f\u5165\u8a72\u8a2d\u5099\u7684\u6a19\u6e96\u5de5\u4f5c\u9805\u76ee\u3002</p> \u4f7f\u7528\u6642\u6a5f \u8aaa\u660e \u8a2d\u5099\u5efa\u6a94 \u4f9d\u7dad\u4fee\u5ee0\u5340\u8a2d\u5099\u6e05\u55ae\u9078\u64c7\u55ae\u4e00\u8a2d\u5099\u5f8c\uff0c\u532f\u5165\u8a72\u8a2d\u5099\u7684\u6a19\u6e96\u5de5\u4f5c\u9805\u6b21\u3001\u6578\u91cf\u8207\u52a0\u6210\u3002 \u8a2d\u5099\u6216\u5de5\u4f5c\u9805\u7570\u52d5 \u8a2d\u5099\u5c0d\u61c9\u5de5\u4f5c\u9805\u76ee\u3001\u6578\u91cf\u6216\u52a0\u6210\u9810\u8a2d\u503c\u7570\u52d5\u6642\uff0c\u65bc\u672c\u7a0b\u5f0f\u91cd\u65b0\u532f\u5165\u3002 \u521d\u6b21\u5efa\u6a94 \u53ef\u5148\u300c\u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u300d\u586b\u5beb\uff0c\u518d\u4ee5\u300c\u6279\u6b21\u532f\u5165\u300d\u4e0a\u50b3\u3002 <p>\u5c0d\u61c9\u6aa2\u67e5\uff1a\u532f\u5165\u6216\u8f09\u5165\u67e5\u8a62\u6642\uff0c\u53ef\u5448\u73fe\u5c0d\u61c9\u4e0d\u5230\u6700\u65b0\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u55ae\u50f9\u7684\u7b46\u6578\u63d0\u793a\uff1b\u6e05\u55ae\u4e2d\u7121\u6cd5\u5c0d\u61c9\u7684\u8a72\u7b46\u4ee5\u7d05\u8272\u986f\u793a\uff0c\u8acb\u81f3 MCR310 \u88dc\u5efa\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u3002</p> <p>\u91cd\u65b0\u532f\u5165\uff1a\u82e5\u6b64\u8a2d\u5099\u5df2\u6709\u5de5\u4f5c\u9805\u76ee\u8cc7\u6599\uff0c\u57f7\u884c\u6279\u6b21\u532f\u5165\u6642\u7cfb\u7d71\u6703\u63d0\u9192\u300c\u662f\u5426\u6e05\u9664\u539f\u6709\u8cc7\u6599\u300d\uff1b\u78ba\u8a8d\u300c\u662f\u300d\u5247\u6a19\u8a18\u522a\u9664\u539f\u8cc7\u6599\u4e26\u5168\u90e8\u65b0\u589e\u91cd\u532f\uff0c\u4ee5\u7dad\u6301\u8cc7\u6599\u5b8c\u6574\u6027\u3002</p>"},{"location":"guides/prototype_MCR320/#_2","title":"\u4e00\u3001\u756b\u9762\u5340\u584a","text":"\u5340\u584a \u8aaa\u660e \u64cd\u4f5c\u63d0\u793a \u203b \u8acb\u5148\u9078\u64c7\u5ee0\u5340\u8207\u8a2d\u5099\uff08\u7dad\u4fee\u5ee0\u5340\u8a2d\u5099\u6e05\u55ae\uff0c\u55ae\u4e00\u8a2d\u5099\uff09\uff0c\u518d\u4e0b\u8f09\u7bc4\u672c\u6216\u6279\u6b21\u532f\u5165\u8a72\u8a2d\u5099\u7684\u6a19\u6e96\u5de5\u4f5c\u9805\u76ee\u3002\u672c\u4f5c\u696d\u4e0d\u5c0d\u61c9\u5408\u7d04\u3002 \u9802\u5217 \u8fd4\u56de\u3001\u7a0b\u5f0f\u6a19\u984c\uff1b\u53f3\u4e0a\u65b9\u300c\ud83d\udcd6 \u64cd\u4f5c\u8aaa\u660e\u300d\u53ef\u958b\u555f\u672c\u8aaa\u660e\u3002 \u64cd\u4f5c\u5217 \u5ee0\u5340\u3001\u8a2d\u5099\u7de8\u865f\uff08\u9078\u55ae\u4e00\u8a2d\u5099\uff09\u2192 \u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u3001\u6279\u6b21\u532f\u5165\u3001\u67e5\u8a62\u3002 \u8aaa\u660e\u5217 \u986f\u793a\u76ee\u524d\u5ee0\u5340\u8207\u8a2d\u5099\uff1b\u5c0d\u61c9\u4e0d\u5230\u6700\u65b0\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u55ae\u50f9\u7b46\u6578\u63d0\u793a\uff08\u7d05\u8272\u3001\u53ef\u9ede\u9078\u5217\u6e05\u55ae\uff09\u3002 \u8a2d\u5099\u5de5\u4f5c\u9805\u76ee\u6e05\u55ae \u7121\u6cd5\u5c0d\u61c9\u5230\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u55ae\u50f9\u7684\u8a72\u7b46\u4ee5\u7d05\u8272\u986f\u793a\uff1b\u8868\u683c\u8207\u5206\u9801\u3001\u532f\u51fa\u5168\u90e8 Excel\u3002"},{"location":"guides/prototype_MCR320/#_3","title":"\u4e8c\u3001\u4e3b\u8981\u6b04\u4f4d","text":"<ul> <li>\u8a2d\u5099\u7de8\u865f\u3001\u8a2d\u5099\u540d\u7a31\u3001\u9805\u6b21\u3001\u5de5\u4f5c\u9805\u76ee\u540d\u7a31\u3001\u6578\u91cf\u3001\u52a0\u6210\u6bd4\u4f8b\uff08%\u3001\u5982 80%\u3001100%\u3001120%\u3001200%\uff09\u3001\u7570\u52d5\u65e5\u671f\u3001\u64cd\u4f5c\uff08\u7de8\u8f2f\uff0f\u522a\u9664\uff09\u3002\u5de5\u4f5c\u9805\u76ee\u82e5\u5c0d\u61c9\u4e0d\u5230 MCR310 \u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u55ae\u50f9\uff0c\u8a72\u7b46\u4ee5\u7d05\u8272\u6a19\u793a\u3002</li> </ul>"},{"location":"guides/prototype_MCR320/#_4","title":"\u4e09\u3001\u64cd\u4f5c\u6b65\u9a5f","text":"<ol> <li>\u5148\u9078\u5ee0\u5340\u8207\u8a2d\u5099\uff1a\u65bc\u5ee0\u5340\u9078\u64c7\u7dad\u4fee\u5ee0\u5340\uff0c\u65bc\u8a2d\u5099\u9078\u64c7\u55ae\u4e00\u8a2d\u5099\uff08\u5c0d\u61c9\u7dad\u4fee\u5ee0\u5340\u8a2d\u5099\u6e05\u55ae\uff09\u3002</li> <li>\u521d\u6b21\u5efa\u6a94\uff1a\u9ede\u300c\u4e0b\u8f09\u532f\u5165\u7bc4\u672c\u300d\u53d6\u5f97 CSV \u7bc4\u672c\uff0c\u4f9d\u6b04\u4f4d\u586b\u5beb\u8a72\u8a2d\u5099\u4e4b\u5de5\u4f5c\u9805\u6b21\u3001\u6578\u91cf\u3001\u52a0\u6210\u6bd4\u4f8b\u5f8c\u518d\u9ede\u300c\u6279\u6b21\u532f\u5165\u300d\u4e0a\u50b3\u3002</li> <li>\u9ede\u300c\u6279\u6b21\u532f\u5165\u300d\u6216\u300c\u67e5\u8a62\u300d\u5f8c\uff0c\u82e5\u6709\u5c0d\u61c9\u4e0d\u5230\u6700\u65b0\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u55ae\u50f9\u4e4b\u7b46\u6578\uff0c\u6703\u986f\u793a\u7d05\u8272\u63d0\u793a\uff0c\u9ede\u9078\u53ef\u5217\u6e05\u55ae\uff1b\u6e05\u55ae\u4e2d\u8a72\u7b46\u5de5\u4f5c\u9805\u76ee\u4ea6\u4ee5\u7d05\u8272\u986f\u793a\u3002</li> <li>\u82e5\u6b64\u8a2d\u5099\u5df2\u6709\u8cc7\u6599\uff0c\u91cd\u65b0\u532f\u5165\u6642\u7cfb\u7d71\u6703\u8a62\u554f\u300c\u662f\u5426\u6e05\u9664\u539f\u6709\u8cc7\u6599\u300d\uff0c\u78ba\u8a8d\u300c\u662f\u300d\u5247\u6a19\u8a18\u522a\u9664\u539f\u8cc7\u6599\u4e26\u5168\u90e8\u65b0\u589e\u91cd\u532f\u3002</li> <li>\u53ef\u300c\u532f\u51fa\u5168\u90e8 Excel\u300d\u532f\u51fa\u6e05\u55ae\uff1b\u55ae\u7b46\u4fee\u6b63\u53ef\u65bc\u6e05\u55ae\u4e0a\u4f7f\u7528\u7de8\u8f2f\uff0f\u522a\u9664\u3002\u52a0\u6210\u6bd4\u4f8b\u5f8c\u7e8c\u53ef\u65bc MCR340 \u8a2d\u5099\u8ffd\u52a0\u8acb\u6b3e\u5efa\u7acb \u4e4b\u52a0\u6210\u4f5c\u696d\u8abf\u6574\u3002</li> </ol>"},{"location":"guides/prototype_MCR320/#_5","title":"\u56db\u3001\u96db\u578b\u8207\u7bc4\u672c\u9023\u7d50","text":"<ul> <li>\u672c\u96db\u578b\uff1a prototype_MCR320.html</li> <li>\u672c\u64cd\u4f5c\u8aaa\u660e\uff1a \u672c\u6a94</li> <li>\u532f\u5165\u7bc4\u672c\uff1a prototype_MCR320_\u532f\u5165\u7bc4\u672c.csv</li> </ul>"}]}