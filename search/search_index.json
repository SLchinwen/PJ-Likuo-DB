05\u55ae\u8207\u96db\u578b\u9810\u89bd","text":""},{"location":"features/#mcr","title":"MCR \u7b2c\u4e00\u968e\u6bb5\uff08\u5df2\u4e0a\u7dda\uff09","text":"\u7a0b\u5f0f\u4ee3\u865f \u540d\u7a31 \u7528\u9014 MCR100 \u5ee0\u5340\u8cc7\u6599\u5efa\u6a94 \u7dad\u8b77\u5ee0\u5340\u4e3b\u6a94 MCR110 \u8a2d\u5099\u8cc7\u6599\u5efa\u6a94 \u7dad\u8b77\u8a2d\u5099\u4e3b\u6a94 MCR130 \u578b\u865f\u5de5\u5e8f\u5efa\u6a94 \u5b9a\u7fa9\u8a2d\u5099\u5de5\u5e8f\u6a21\u677f MCR140 \u7dad\u8b77\u5408\u7d04\u5efa\u6a94 \u5408\u7d04\u4e3b\u6a94\u8207\u6848\u4ef6\u8a2d\u5b9a MCR150 \u7dad\u8b77\u6848\u4ef6\u8a2d\u5099\u5efa\u6a94 \u6848\u4ef6\u8207\u8a2d\u5099\u5c0d\u61c9 MCR160 \u7dad\u8b77\u8a2d\u5099\u81ea\u8a02\u5de5\u5e8f\u5efa\u6a94 \u975e\u6a19\u6e96\u5de5\u5e8f\u7dad\u8b77 MCR210 \u73fe\u5834\u4eba\u54e1\u8a2d\u5099\u5de5\u5e8f\u56de\u5831 \u73fe\u5834\u56de\u5831\u8207\u7167\u7247\u4e0a\u50b3 MCR220 \u56de\u5831\u5be9\u6838 \u5be9\u6838\u3001\u6838\u51c6\u8207\u9000\u56de MCR230 \u7dad\u8b77\u8a2d\u5099\u6210\u679c\u5831\u8868 \u6210\u679c\u5831\u8868\u7522\u51fa MCR231 \u7dad\u8b77\u8a2d\u5099\u9032\u5ea6\u8ffd\u8e64\u770b\u677f \u9032\u5ea6\u8ffd\u8e64\u8207\u67e5\u8a62 <p>\u2192 \u7b2c\u4e00\u968e\u6bb5\u64cd\u4f5c\u624b\u518a</p>"},{"location":"features/#mcr_1","title":"MCR \u7b2c\u4e8c\u968e\u6bb5\uff08\u958b\u767c\u4e2d\uff09\u2014 \u96db\u578b\u9810\u89bd","text":"\u7a0b\u5f0f\u4ee3\u865f \u540d\u7a31 \u96db\u578b\u9810\u89bd \u64cd\u4f5c\u8aaa\u660e MCR310 \u5ba2\u6236\u5408\u7d04\u5de5\u4f5c\u9805\u76ee\u5efa\u6a94 \u958b\u555f\u96db\u578b \u64cd\u4f5c\u8aaa\u660e MCR320 \u5ba2\u6236\u8a2d\u5099\u5de5\u4f5c\u9805\u76ee\u5efa\u6a94 \u958b\u555f\u96db\u578b \u64cd\u4f5c\u8aaa\u660e \u2014 \u540a\u8eca\u6392\u7a0b\u5100\u9336\u677f \u958b\u555f\u96db\u578b \u66ab\u505c\u4e2d"},{"location":"features/#hr","title":"HR \u51fa\u7f3a\u52e4\u7cfb\u7d71\uff08\u66ab\u505c\u4e2d\uff09","text":"\u6a21\u7d44 \u7528\u9014 \u5237\u5361\uff0f\u8fa8\u8b58\u6574\u5408 \u532f\u5165\u5237\u5361 Log\u3001\u53bb\u91cd \u51fa\u52e4\u5224\u65b7\u5f15\u64ce \u81ea\u52d5\u5224\u65b7\u4e0a\u4e0b\u73ed\u8207\u5de5\u6642 \u9ede\u540d\u8207\u4eba\u5de5\u4ecb\u5165 \u8a2d\u5099\u6545\u969c\u6642\u6279\u6b21\u88dc\u5165 \u52a0\u73ed\u8207\u6cd5\u898f\u7a3d\u6838 \u6cd5\u5b9a\u52a0\u73ed\u8a08\u7b97\u8207\u8d85\u9650\u8655\u7406 \u6708\u7d50\u7b97\u8207\u5047\u5225 \u81ea\u52d5\u7522\u51fa\u66e0\u8077/\u9072\u5230/\u65e9\u9000 <p>\u2192 \u96db\u578b\u958b\u767c\u66ab\u505c\u4e2d\uff0c\u5b8c\u6210\u5f8c\u5c07\u65bc\u6b64\u9801\u66f4\u65b0\u9023\u7d50\u3002</p>"},{"location":"scope/","title":"\u7cfb\u7d71\u7bc4\u570d\u8207\u968e\u6bb5\u898f\u5283","text":""},{"location":"scope/#mcr","title":"MCR \u5de5\u7a0b\u7dad\u8b77\u7ba1\u7406\u7cfb\u7d71","text":""},{"location":"scope/#_2","title":"\u7b2c\u4e00\u968e\u6bb5\uff08\u5df2\u5b8c\u6210\uff09","text":"<ul> <li>\u5ee0\u5340\u3001\u8a2d\u5099\u3001\u578b\u865f\u5de5\u5e8f\u3001\u5408\u7d04\u3001\u6848\u4ef6\u5efa\u6a94</li> <li>\u73fe\u5834\u56de\u5831\u3001\u5be9\u6838\u3001\u6210\u679c\u5831\u8868\u3001\u9032\u5ea6\u8ffd\u8e64</li> </ul>"},{"location":"scope/#_3","title":"\u7b2c\u4e8c\u968e\u6bb5\uff08\u9032\u884c\u4e2d\uff09","text":"<ul> <li>\u5de5\u7a0b\u56de\u5831\u62cd\u7167\u3001\u8acb\u6b3e\u7d50\u7b97</li> <li>\u57fa\u672c\u8cc7\u6599\u6279\u6b21\u532f\u5165</li> <li>\u540a\u8eca\u6392\u7a0b\uff08\u66ab\u505c\u4e2d\uff09</li> </ul>"},{"location":"scope/#hr","title":"HR \u51fa\u7f3a\u52e4\u7cfb\u7d71\uff08\u66ab\u505c\u4e2d\uff09","text":"<ul> <li>\u5237\u5361\u532f\u5165\u8207\u51fa\u52e4\u5224\u65b7</li> <li>\u9ede\u540d\u8f14\u52a9\u3001\u6708\u7d50\u7b97\u3001\u6cd5\u898f\u7a3d\u6838</li> </ul>"},{"location":"scope/#_4","title":"\u968e\u6bb5\u85cd\u5716","text":"<pre><code>timeline\n    title \u7acb\u570b\u5de5\u7a0b\u7cfb\u7d71\u767c\u5c55\u85cd\u5716\n    2025 : MCR \u7b2c\u4e00\u968e\u6bb5\u4e0a\u7dda\n         : \u57fa\u790e\u8cc7\u6599\u5efa\u6a94\n         : \u73fe\u5834\u56de\u5831\u8207\u5be9\u6838